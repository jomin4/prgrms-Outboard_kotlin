{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git remote -v)",
      "Bash(git remote:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(gradlew.bat build:*)",
      "Bash(gradlew.bat test:*)",
      "Bash(.\\gradlew.bat build:*)",
      "Bash(.\\gradlew.bat test:*)",
      "Bash(./gradlew build:*)",
      "Bash(./gradlew test:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git branch -D:*)",
      "Bash(git branch --delete --force:*)",
      "Bash(git checkout -- .:*)",
      "Bash(git restore .:*)",
      "Bash(git clean -f:*)",
      "Bash(rm -rf:*)"
    ]
  }
}
